// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL") // uses connection pooling
}

model Band {
  id       String    @id @default(cuid())
  name     String
  admin    User      @relation("BandAdmin", fields: [userId], references: [id])
  userId   String
  bio      String?
  location String?
  genre    String?
  members  User[]
  setlists Setlist[]
  songs    Song[]

  @@unique([userId, name])
}

model Song {
  id             String    @id @default(cuid())
  name           String
  lengthSeconds  Int
  timeSignatures String?
  lyrics         String?
  tags           String?
  setlists       Setlist[]
  band           Band      @relation(fields: [bandId], references: [id])
  bandId         String
}

model Setlist {
  id     String @id @default(cuid())
  name   String
  songs  Song[]
  band   Band   @relation(fields: [bandId], references: [id])
  bandId String
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  administrator Band[]    @relation("BandAdmin")
  bands         Band[]
  profile       Profile?
  Chat          Chat?     @relation(fields: [chatId], references: [id])
  chatId        String?
  Message       Message[]
}

model Profile {
  id         String      @id @default(cuid())
  userId     String      @unique
  bio        String?
  location   String?
  joined     DateTime
  influences Influence[]
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Influence {
  id        String   @id @default(cuid())
  name      String
  Profile   Profile? @relation(fields: [profileId], references: [id])
  profileId String?
}

model Chat {
  id       String    @id @default(cuid())
  messages Message[]
  members  User[]
}

model Message {
  id        String   @id @default(cuid())
  chat      Chat     @relation(fields: [chatId], references: [id])
  chatId    String
  sender    User     @relation(fields: [senderId], references: [id])
  senderId  String
  content   String
  createdAt DateTime

  @@unique([chatId, id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
