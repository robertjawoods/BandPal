// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // uses connection pooling
  directUrl = env("DIRECT_DATABASE_URL") // uses direct connection
}

model Band {
  id                String    @id @default(uuid())
  name              String
  admin             User      @relation("BandAdmin", fields: [userId], references: [id])
  userId            String
  bio               String?
  location          String?
  genre             String?
  members           User[]
  setlists          Setlist[]
  songs             Song[]
  lookingForMembers Boolean   @default(false)

  @@unique([userId, name])
}

model Song {
  id             String    @id @default(uuid())
  name           String
  lengthSeconds  Int
  timeSignatures String?
  lyrics         String?
  tags           String?
  setlists       Setlist[]
  band           Band      @relation(fields: [bandId], references: [id])
  bandId         String
}

model Setlist {
  id     String @id @default(uuid())
  name   String
  songs  Song[]
  band   Band   @relation(fields: [bandId], references: [id])
  bandId String
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  administrator Band[]    @relation("BandAdmin")
  bands         Band[]
  profile       Profile?
  Chats         Chat[]
  Message       Message[]
}

model Profile {
  id         String      @id @default(uuid())
  userId     String      @unique
  bio        String?
  location   String?
  joined     DateTime
  influences Influence[]
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role[]
  isPublic       Boolean     @default(true)
  lookingForBand Boolean     @default(false)
  allowMessages  Boolean     @default(true)
  image          String?

}

model Influence {
  id        String   @id
  name      String
  Profile   Profile? @relation(fields: [profileId], references: [id])
  profileId String?
}

model Chat {
  id       String    @id @default(uuid())
  messages Message[]
  members  User[]
}

model Message {
  id        String   @id @default(uuid())
  chat      Chat     @relation(fields: [chatId], references: [id])
  chatId    String
  sender    User     @relation(fields: [senderId], references: [id])
  senderId  String
  content   String
  createdAt DateTime @default(now())

  @@unique([chatId, id])
}

model Role {
  id        String   @id @default(uuid())
  name      String
  Profile   Profile[]
}