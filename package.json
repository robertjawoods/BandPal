{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --fix",
    "clean": "rimraf .turbo node_modules dist",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "format": "prisma format",
    "generate": "prisma generate",
    "prebuild": "bun run generate",
    "predev": "bun run generate",
    "studio": "prisma studio",
    "docker": "docker compose up -d",
    "start:migrate:prod": "prisma migrate deploy && pnpm start",
    "index": "ts-node index-users.ts",
    "postinstall": "prisma generate --no-engine",
    "prepare": "husky", 
    "supabase:start": "supabase start -x vector", 
    "supabase:stop": "supabase stop --no-backup"
  },
  "dependencies": {
    "@algolia/autocomplete-js": "^1.18.1",
    "@algolia/autocomplete-plugin-redirect-url": "^1.18.1",
    "@algolia/autocomplete-theme-classic": "^1.18.1",
    "@prisma/client": "^6.5.0",
    "@prisma/extension-accelerate": "^1.2.2",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "algoliasearch": "^4.24.0",
    "next": "15.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supabase": "2.19.8",
    "tsx": "^4.19.3",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@next/eslint-plugin-next": "^14.2.24",
    "@types/node": "^20.17.24",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.21",
    "dotenv": "^16.4.7",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.1.0",
    "husky": "^9.1.7",
    "postcss": "^8.5.3",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
