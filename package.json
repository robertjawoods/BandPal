{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed/seed.ts"
  },
  "scripts": {
    "dev": "infisical run --env=dev -- next dev",
    "build": "next build",
    "start:prod": "infisical run --env=prod next start",
    "lint": "next lint --fix",
    "clean": "rimraf .turbo node_modules dist",
    "db:migrate:deploy": "infisical run --env=prod -- prisma migrate deploy",
    "db:migrate:dev": "infisical run --env=dev -- prisma migrate dev && prisma generate --no-hints",
    "db:reset:prod": "infisical run --env=prod --  prisma migrate reset --force",
    "db:reset:dev": "infisical run --env=dev --  prisma migrate reset --force",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:format": "prisma format",
    "db:generate": "prisma generate --no-hints",
    "prebuild": "bun run db:generate",
    "predev": "bun run db:generate",
    "studio": "prisma studio",
    "docker": "docker compose up -d",
    "start:migrate:prod": "infisical run --env=prod prisma migrate deploy && pnpm start",
    "index": "ts-node index-users.ts",
    "postinstall": "prisma generate --no-engine --no-hints",
    "prepare": "husky",
    "supabase:start": "supabase start -x vector",
    "supabase:stop": "supabase stop --no-backup",
    "db:migrate:diff": "infisical run --env=prod -- prisma migrate diff --from-schema-datamodel \"./prisma/schema.prisma\" --to-schema-datasource",
    "test:e2e:ci": "playwright test --no-deps",
    "test:e2e": "playwright test --ui",
    "test:e2e:chrome": "playwright test --project=chromium"
  },
  "dependencies": {
    "@algolia/autocomplete-js": "^1.18.1",
    "@algolia/autocomplete-plugin-redirect-url": "^1.18.1",
    "@algolia/autocomplete-theme-classic": "^1.18.1",
    "@playwright/test": "^1.51.1",
    "@prisma/client": "^6.5.0",
    "@prisma/extension-accelerate": "^1.2.2",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "algoliasearch": "^4.24.0",
    "next": "15.2.3",
    "next-safe-action": "^7.10.4",
    "playwright": "^1.51.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supabase": "2.19.8",
    "tsx": "^4.19.3",
    "yup": "^1.6.1",
    "zod-form-data": "^2.0.7"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@infisical/cli": "^0.36.19",
    "@next/eslint-plugin-next": "^14.2.24",
    "@types/node": "^20.17.24",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.21",
    "dotenv": "^16.4.7",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.1.0",
    "husky": "^9.1.7",
    "postcss": "^8.5.3",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "@types/bun": "latest"
  },
  "packageManager": "bun@1.2.3"
}
